<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <Import Project="..\..\publish\version.props" />
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net30;net45</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <EnableDefaultApplicationDefinition>false</EnableDefaultApplicationDefinition>
    <ApplicationIcon>..\..\assets\app.ico</ApplicationIcon>
    <ApplicationManifest>Properties\app.manifest</ApplicationManifest>
    <AppConfig>Properties\app.config</AppConfig>
    <StartupObject>WinCraft.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\Directory.Build.props" Link="Properties\Directory.Build.props" />
    <None Include="..\..\publish\version.props" Link="Properties\version.props" />
    <None Include="..\..\assets\app.ico" Link="Properties\app.ico" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WinCraft.Core\WinCraft.Core.csproj" />
    <ProjectReference Include="..\WinCraft.Lzma\WinCraft.Lzma.csproj"
                      ReferenceOutputAssembly="false"
                      OutputItemType="Content"
                      CopyToOutputDirectory="PreserveNewest"
                      PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.VisualBasic" />
  </ItemGroup>


</Project>
